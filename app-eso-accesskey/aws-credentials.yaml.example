# EXAMPLE ONLY - KHÔNG commit file thật vào git
# Tạo secret thật bằng lệnh:
#   kubectl create secret generic aws-credentials \
#     --from-literal=access-key-id=AKIAXXXXXXXX \
#     --from-literal=secret-access-key=xxxxxxxxxx \
#     -n demo
#
# Hoặc dùng file này sau khi đổi giá trị:
#   cp aws-credentials.yaml.example aws-credentials.yaml
#   # Sửa giá trị thật vào rồi chạy:
#   kubectl apply -f aws-credentials.yaml
#   # Xóa file sau khi apply xong
apiVersion: v1
kind: Secret
metadata:
  name: aws-credentials
  namespace: demo
type: Opaque
stringData:
  access-key-id: "YOUR_ACCESS_KEY_ID"
  secret-access-key: "YOUR_SECRET_ACCESS_KEY"
